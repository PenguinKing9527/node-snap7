{
  "name": "@node-snap7/core",
  "version": "0.1.0",
  "description": "Async-first TypeScript S7 communication library for Siemens PLCs",
  "license": "MIT",
  "private": false,
  "packageManager": "pnpm@10.15.1",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "clean": "rimraf dist coverage",
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"src/**/*.ts\" \"test/**/*.ts\"",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "verify": "pnpm run lint && pnpm run typecheck && pnpm run test && pnpm run build",
    "release:check": "pnpm run verify && npm pack --dry-run"
  },
  "devDependencies": {
    "@eslint/js": "^9.25.0",
    "@types/node": "^22.15.3",
    "@vitest/coverage-v8": "^3.1.2",
    "eslint": "^9.25.0",
    "globals": "^16.0.0",
    "rimraf": "^6.0.1",
    "tsup": "^8.4.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.30.1",
    "vitest": "^3.1.2"
  }
}
